{
  "kind": "collectionType",
  "collectionName": "packages",
  "info": {
    "singularName": "package",
    "pluralName": "packages",
    "displayName": "Package",
    "description": "Tour packages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "fullDescription": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "duration": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "basePrice": {
      "type": "decimal",
      "required": true
    },
    "baseCurrency": {
      "type": "enumeration",
      "enum": ["EGP", "USD", "EUR", "GBP"],
      "default": "EGP",
      "required": true
    },
    "discountPrice": {
      "type": "decimal"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "packages"
    },
    "destinations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::destination.destination",
      "inversedBy": "packages"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "included": {
      "type": "component",
      "repeatable": true,
      "component": "package.included-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "excluded": {
      "type": "component",
      "repeatable": true,
      "component": "package.excluded-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "itinerary": {
      "type": "component",
      "repeatable": true,
      "component": "package.itinerary-day",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "package.faq",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "priceOverrides": {
      "type": "component",
      "repeatable": true,
      "component": "package.price-override"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}