{
  "kind": "collectionType",
  "collectionName": "inquiries",
  "info": {
    "singularName": "inquiry",
    "pluralName": "inquiries",
    "displayName": "Inquiry",
    "description": "Booking inquiries from users"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "preferredDate": {
      "type": "date"
    },
    "travelers": {
      "type": "integer",
      "min": 1
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "confirmed", "closed"],
      "default": "new"
    },
    "package": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::package.package"
    },
    "hotel": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::hotel.hotel"
    }
  }
}